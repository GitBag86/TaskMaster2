# TaskMaster2 — docker-compose environment
# Skopiuj do .env (obok docker-compose.yml) i dostosuj wartości.
# Pełna lista opcji (INVITE_TOKEN_TTL_DAYS, SUPER_ADMIN_LANDING, MAIL_* i in.)
# znajduje się w oryginalnym pliku: git show HEAD:.env.example

# ============================================================
# WYMAGANE — wygeneruj SECRET_KEY:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
SECRET_KEY=change-me-to-random-64-char-hex

# ============================================================
# OPCJONALNE (domyślne wartości są rozsądne dla localhost)
# ============================================================
PORT=5000
FLASK_ENV=production
CORS_ORIGINS=http://localhost:5000
SESSION_COOKIE_SECURE=false
LOG_LEVEL=INFO
SIGNUP_MODE=invite_only
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=dakos1admin2
DEFAULT_ADMIN_EMAIL=admin@taskmaster.local
MAIL_SUPPRESS_SEND=true
