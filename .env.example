# TaskMaster2 Environment Configuration
# Skopiuj do .env i uzupełnij wartości

# ============================================================
# WYMAGANE
# ============================================================

# Klucz sesji - WYGENERUJ NOWY przed pierwszym uruchomieniem:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-32-byte-hex

# Lista dozwolonych origins dla CORS (oddzielone przecinkami)
# Lokalnie: http://localhost:5000
# Produkcyjnie: https://twoja-domena.com,https://ip-serwera
CORS_ORIGINS=http://localhost:5000

# Publiczny adres aplikacji uzywany w linkach e-mail i jobach w tle
PUBLIC_BASE_URL=https://localhost

# ============================================================
# OPCJONALNE
# ============================================================

# Tryb Flaska: development | production
FLASK_ENV=production

# Async mode dla Socket.IO: threading (lokalnie) | gthread (Docker/Gunicorn)
SOCKETIO_ASYNC_MODE=gthread

# Background scheduler (powiadomienia o terminach)
ENABLE_SCHEDULER=true

# Poziom logowania
LOG_LEVEL=INFO

# ============================================================
# TEAM WORKSPACES (multi-tenancy)
# ============================================================

# Tryb rejestracji nowych kont:
#   disabled     - rejestracja wylaczona (administrator zaklada konta recznie)
#   invite_only  - wymagany token zaproszenia od menedzera (DOMYSLNE)
#   default_team - nowe konta laduja w zespole "Default" jako zwykly user
SIGNUP_MODE=invite_only

# Czas zycia tokena zaproszenia (dni)
INVITE_TOKEN_TTL_DAYS=7

# Strona startowa dla super-admina po zalogowaniu
SUPER_ADMIN_LANDING=/admin/teams

# ============================================================
# E-MAIL (opcjonalne - powiadomienia)
# ============================================================

# Pozostaw puste, żeby wyłączyć wysyłanie maili
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
# Ustaw na True wylacznie w testach/staging - aplikacja udaje wysylke i nic nie idzie do SMTP.
MAIL_SUPPRESS_SEND=False
# Maksymalny czas oczekiwania na odpowiedz serwera SMTP (sekundy). Chroni przed zawieszaniem requestow.
MAIL_TIMEOUT=10
# Asynchroniczna wysylka w puli watkow (zalecane: True). Ustaw False jesli musisz miec synchroniczne potwierdzenie.
MAIL_ASYNC=True

# ============================================================
# DOMYŚLNY ADMIN (bootstrap przy pierwszym starcie)
# ============================================================

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-strong-password
DEFAULT_ADMIN_EMAIL=admin@taskmaster.local
# Ustaw true tylko awaryjnie, gdy chcesz zresetowac haslo istniejacego admina przy starcie.
DEFAULT_ADMIN_RESET_PASSWORD=false
