# TaskMaster2 Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# LOCAL DEVELOPMENT (SQLite - Default)
# ============================================================
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5000

# Development/Production mode
FLASK_ENV=development

# Enable background scheduler (disabled in production via Cloud Run)
ENABLE_SCHEDULER=true

# ============================================================
# LOCAL DEVELOPMENT WITH POSTGRES
# (Useful for testing Cloud Run setup locally)
# ============================================================
# Uncomment and set these to test with Postgres locally:
# DATABASE_URL=postgresql://appuser:password@localhost:5432/taskmaster_db

# ============================================================
# GOOGLE CLOUD RUN + CLOUD SQL DEPLOYMENT
# (Use Cloud SQL Auth Proxy connection - Recommended)
# ============================================================
# Uncomment and set these for Cloud Run deployment:
#
# Cloud SQL connection via Unix socket (most secure)
# INSTANCE_UNIX_SOCKET=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
#
# Database credentials
# DB_NAME=taskmaster_db
# DB_USER=appuser
# DB_PASSWORD=your_strong_password_here
#
# Flask configuration
# SECRET_KEY=generate_with_openssl_rand_hex_32
# FLASK_ENV=production
#
# CORS for Cloud Run domain
# CORS_ORIGINS=https://taskmaster2-xxx.a.run.app,https://yourdomain.com
#
# Disable scheduler in Cloud Run (use Cloud Tasks instead)
# ENABLE_SCHEDULER=false
#
# Cloud Run requires port 8080
# PORT=8080

# ============================================================
# ALTERNATIVE: CLOUD RUN WITH PUBLIC IP (Less Secure)
# ============================================================
# If Cloud SQL Auth Proxy causes issues, use standard DATABASE_URL:
#
# DATABASE_URL=postgresql://appuser:password@CLOUD_SQL_PUBLIC_IP:5432/taskmaster_db
# SECRET_KEY=generate_with_openssl_rand_hex_32
# FLASK_ENV=production
# CORS_ORIGINS=https://taskmaster2-xxx.a.run.app
# PORT=8080

# ============================================================
# OPTIONAL: EMAIL/MAIL CONFIGURATION
# ============================================================
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USE_SSL=False
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=noreply@taskmaster2.com

# ============================================================
# OPTIONAL: LOGGING
# ============================================================
# LOG_LEVEL=INFO

