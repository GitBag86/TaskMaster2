# TaskMaster2 Environment Configuration
# Skopiuj do .env i uzupełnij wartości

# ============================================================
# WYMAGANE
# ============================================================

# Klucz sesji - WYGENERUJ NOWY przed pierwszym uruchomieniem:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-32-byte-hex

# Lista dozwolonych origins dla CORS (oddzielone przecinkami)
# Lokalnie: http://localhost:5000
# Produkcyjnie: https://twoja-domena.com,https://ip-serwera
CORS_ORIGINS=http://localhost:5000

# Publiczny adres aplikacji uzywany w linkach e-mail i jobach w tle
PUBLIC_BASE_URL=https://localhost

# ============================================================
# OPCJONALNE
# ============================================================

# Tryb Flaska: development | production
FLASK_ENV=production

# Async mode dla Socket.IO: threading (lokalnie) | gthread (Docker/Gunicorn)
SOCKETIO_ASYNC_MODE=gthread

# Background scheduler (powiadomienia o terminach)
ENABLE_SCHEDULER=true

# Poziom logowania
LOG_LEVEL=INFO

# ============================================================
# E-MAIL (opcjonalne - powiadomienia)
# ============================================================

# Pozostaw puste, żeby wyłączyć wysyłanie maili
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
MAIL_SUPPRESS_SEND=False

# ============================================================
# DOMYŚLNY ADMIN (bootstrap przy pierwszym starcie)
# ============================================================

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-me-strong-password
DEFAULT_ADMIN_EMAIL=admin@taskmaster.local
# Ustaw true tylko awaryjnie, gdy chcesz zresetowac haslo istniejacego admina przy starcie.
DEFAULT_ADMIN_RESET_PASSWORD=false
