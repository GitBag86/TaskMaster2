# Security hardening for npm installs
#
# ignore-scripts prevents any postinstall / preinstall scripts from running
# during `npm install`, blocking supply-chain attacks where a compromised
# dependency executes arbitrary code (e.g. dependency confusion, malicious
# packages). Build steps (tsc, vite build) are run explicitly via npm run build,
# not via lifecycle scripts, so this is safe.
ignore-scripts=true

# Fail the install if a package's integrity hash doesn't match the lockfile.
# Prevents tampered packages from being installed.
# (Enabled by default in npm v7+, explicit here for documentation.)
package-lock=true
